{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuiteWhisper",
  "version": "0.1.0",
  "identifier": "local.quitewhisper.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "QuiteWhisper",
        "width": 920,
        "height": 760,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "QuiteWhisper",
        "width": 380,
        "height": 84,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "category": "Productivity",
    "shortDescription": "Local push-to-talk dictation",
    "longDescription": "QuiteWhisper records while a hotkey is held, transcribes locally with Whisper, and pastes text into the active field."
  }
}
